# Build and run the zis with args
// Example:
// only br fetch https://github.com/opencv/opencv/archive/refs/tags/5.0.0.tar.gz
br(args..):
    zig build run -- {{ args }}

# Publish and run the zis with args
pr(args..) & p:
    ./zig-out/bin/zis {{ args }}

# Publish the zis
p(static="false"):
    zig build -Doptimize=ReleaseFast -Dstrip=true -Dstatic={{ static }}
    echo 'zis has been published.'

# Test the zis
t():
    zig build test
    echo 'zis passed all the tests.'

# Clean the zis
c():
    echo 'Cleaning zis...'
    rm -rf .zig-cache zig-out
    echo 'zis has been cleaned.'

# Format codebase
f():
    zig fmt src/ libcommand/
    echo 'Formatted.'

# Install the local zis binary
i() ? @os("windows") & p shell?=pwsh:
    New-Item -ItemType Directory -Force -Path (Join-Path $env:LOCALAPPDATA "Programs\Zis") | Out-Null
    Copy-Item ./zig-out/bin/zis.exe -Destination (Join-Path $env:TEMP "zis-install-staged.exe") -Force
    $parentPid = (Get-CimInstance Win32_Process -Filter "ProcessId=$PID").ParentProcessId; $shellPath = (Get-Process -Id $PID).Path; $stagedPath = Join-Path $env:TEMP "zis-install-staged.exe"; $installPath = Join-Path $env:LOCALAPPDATA "Programs\Zis\zis.exe"; $script = "Wait-Process -Id $parentPid; Copy-Item -LiteralPath '$stagedPath' -Destination '$installPath' -Force; Remove-Item -LiteralPath '$stagedPath' -Force"; $encoded = [Convert]::ToBase64String([Text.Encoding]::Unicode.GetBytes($script)); Start-Process -WindowStyle Hidden -FilePath $shellPath -ArgumentList "-NoProfile", "-EncodedCommand", $encoded
    Write-Output "Installed zis to: $(Join-Path $env:LOCALAPPDATA "Programs\Zis\zis.exe")"

i() & p:
    mkdir -p "$HOME/.local/bin"
    cp ./zig-out/bin/zis "$HOME/.local/bin/.zis-install"
    chmod +x "$HOME/.local/bin/.zis-install"
    mv "$HOME/.local/bin/.zis-install" "$HOME/.local/bin/zis"
    echo "Installed zis to: $HOME/.local/bin/zis"

# Clean all
ca() & c & lib.c:
    echo 'All done.'

# Lib command
[lib]
# Run the lib tests.
t():
    cd libcommand && zig build test
    cd ..

# Clean the lib
c():
    echo 'Cleaning libcommand...'
    rm -rf libcommand/.zig-cache libcommand/zig-out
    echo 'lib has been cleaned.'
