# Run ths zis with args.
// Example:
// only r fetch https:/code.kercy666.com/Kercy/zis
r(args..):
    zig build run -- {{ args }}

# Test the zis.
t():
    zig build test
    echo 'zis passed all the tests.'

# Publish the zis.
p(static="false"):
    zig build -Doptimize=ReleaseFast -Dstrip=true -Dstatic={{ static }}
    echo 'zis has been published.'

# Clean the zis.
c():
    echo 'Cleaning zis...'
    rm -rf .zig-cache zig-out
    echo 'zis has been cleaned.'

# Format codebase.
f():
    zig fmt src/ libcommand/
    echo 'Formatted.'

# Clean all.
ca() & c & lib.c:
    echo 'All done.'

# Commit all.
cmt(content..):
    git add -A && git commit -m "{{ content }}"
    git log --oneline -5

# Lib command.
[lib]
# Run the lib tests.
t():
    cd libcommand && zig build test
    cd ..

# Clean the lib.
c():
    echo 'Cleaning libcommand...'
    rm -rf libcommand/.zig-cache libcommand/zig-out
    echo 'lib has been cleaned.'
