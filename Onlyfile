# Run ths zis with args.
// Example:
// only r fetch https://code.kercy666.com/Kercy/zis.git
r(args..):
    zig build run -- {{ args }}

# Test the zis.
t():
    zig build test
    echo 'zis passed all the tests.'

# Publish the zis.
p():
    zig build -Doptimize=ReleaseFast -Dstrip=true
    echo 'zis has been published.'

# Clean the zis.
c():
    echo 'Cleaning zis...'
    rm -rf .zig-cache zig-out
    echo 'zis has been cleaned.'

# Format codebase.
f():
    zig fmt src/ libcommand/
    echo 'Formatted.'

# Clean all.
ca() & c & lib.c:
    echo 'All done.'

# Lib command.
[lib]
# Run the lib tests.
t():
    cd libcommand && zig build test
    cd ..

# Clean the lib.
c():
    echo 'Cleaning libcommand...'
    rm -rf libcommand/.zig-cache libcommand/zig-out
    echo 'lib has been cleaned.'
